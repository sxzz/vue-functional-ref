{
  "name": "vue-functional-ref",
  "type": "module",
  "version": "0.7.2",
  "packageManager": "pnpm@11.0.4",
  "description": "Functional-style refs for Vue",
  "author": "Kevin Deng <sxzz@sxzz.moe>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/sxzz",
  "homepage": "https://github.com/sxzz/vue-functional-ref#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sxzz/vue-functional-ref.git"
  },
  "bugs": {
    "url": "https://github.com/sxzz/vue-functional-ref/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./esbuild": "./dist/esbuild.js",
    "./rolldown": "./dist/rolldown.js",
    "./rollup": "./dist/rollup.js",
    "./vite": "./dist/vite.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "types.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "pnpm run lint --fix",
