    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "^8.0.0",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/node": "^25.6.0",
    "@vue/reactivity": "^3.5.33",
    "@vue/shared": "^3.5.33",
    "bumpp": "^11.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "expect-type": "^1.3.0",
    "prettier": "^3.8.3",
    "rolldown": "1.0.0-rc.18",
    "rollup": "^4.60.2",
    "tsdown": "^0.21.10",
    "tsdown-preset-sxzz": "^0.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue": "^3.5.33"
  },
  "prettier": "@sxzz/prettier-config"
}
